# ---------------------------------------------------------------------------
# Optional: contact-form submission endpoint.
#
# If set, the contact form POSTs to this URL (e.g. a Formspree/Getform/Basin
# endpoint). If left unset, the form gracefully falls back to opening the
# visitor's email client with a pre-filled message (mailto:).
#
# Copy this file to `.env.local` and fill in your endpoint to enable it.
# ---------------------------------------------------------------------------
NEXT_PUBLIC_FORM_ENDPOINT=

# ---------------------------------------------------------------------------
# Canonical site URL, used for SEO (canonical tag, Open Graph, sitemap).
# Set this to your deployed domain, e.g. https://yourname.dev
# ---------------------------------------------------------------------------
NEXT_PUBLIC_SITE_URL=

# ---------------------------------------------------------------------------
# Sanity CMS (optional). When these are set, the site reads content from your
# Sanity project and you edit everything at /studio. When unset, the site
# renders from the local fallback content in src/content/site.ts.
#
# Get these after creating a free project at https://www.sanity.io/manage:
#   - Project ID:  Project settings → API
#   - Dataset:     usually "production"
# ---------------------------------------------------------------------------
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
